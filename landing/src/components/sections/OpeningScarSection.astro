---
import { site } from "../../data/site.ts";
import { withBase } from "../../lib/paths.ts";

const section = site.presentation.opening;
---

<section id="manual" class="presentation-slide overflow-hidden">
  <img
    src={withBase("/images/goos_transparent.png")}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute bottom-[-5rem] right-[-6rem] hidden w-[20rem] opacity-[0.15] lg:block xl:w-[30rem]"
  />

  <div class="container-shell relative z-10 grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
    <div>
      <p class="presentation-kicker">{section.step} / {section.eyebrow}</p>
      <h1 class="mt-4 max-w-4xl text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
        {section.title}
      </h1>
      <p class="section-copy mt-6 max-w-2xl">{section.body}</p>
      <p class="presentation-quote mt-8 max-w-xl">{section.narration}</p>
      <p class="mt-8 max-w-xl text-sm font-medium leading-relaxed text-cyan-100/80">{section.bridge}</p>
    </div>

    <div class="grid gap-5">
      <div class="grid gap-5 md:grid-cols-2">
        {section.comparison.map((item) => (
          <div class="presentation-note">
            <span class="presentation-chip">{item.label}</span>
            <h2 class="mt-4 text-2xl font-semibold tracking-tight text-foreground">{item.title}</h2>
            <p class="mt-3 text-base leading-relaxed text-muted-foreground">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
