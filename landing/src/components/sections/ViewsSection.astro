---
import SectionHeading from "../ui/SectionHeading.astro";
import { site } from "../../data/site.ts";
import { withBase } from "../../lib/paths.ts";
---

<section id="views" class="py-24 sm:py-32">
  <div class="container-shell">
    <SectionHeading eyebrow={site.views.eyebrow} title={site.views.title} intro={site.views.intro} />

    <div class="mt-14 grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
      <div class="surface-panel overflow-hidden">
        <div class="border-b border-white/10 px-6 py-4 sm:px-8">
          <p class="text-sm uppercase tracking-[0.18em] text-cyan-300/80">Testing view</p>
          <h3 class="mt-2 text-2xl font-semibold text-foreground">Run suites, scan history, inspect failures</h3>
        </div>
        <img
          src={withBase("/images/dashboard-view.png")}
          alt="Goose dashboard testing view"
          class="w-full border-t border-white/5 object-cover"
        />
      </div>

      <div class="grid gap-6">
        {site.views.items.map((item, index) => (
          <div class:list={[
            "rounded-[1.5rem] border p-6 sm:p-7",
            index === 0
              ? "border-l-[3px] border-l-cyan-400/60 border-t border-r border-b border-white/10 bg-white/[0.03]"
              : index === 1
                ? "border-l-[3px] border-l-warning/50 border-t border-r border-b border-white/10 bg-white/[0.02]"
                : "border-l-[3px] border-l-emerald-400/50 border-t border-r border-b border-white/10 bg-white/[0.02]",
          ]}>
            <p class:list={[
              "text-sm font-medium uppercase tracking-[0.18em]",
              index === 0 ? "text-cyan-300/80" : index === 1 ? "text-warning/80" : "text-emerald-300/80",
            ]}>{item.label}</p>
            <h3 class="mt-3 text-2xl font-semibold text-foreground">{item.name}</h3>
            <p class="mt-3 text-base leading-relaxed text-slate-300">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
