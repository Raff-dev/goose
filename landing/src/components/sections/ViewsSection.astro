---
import SectionHeading from "../ui/SectionHeading.astro";
import { site } from "../../data/site.ts";
import { withBase } from "../../lib/paths.ts";

const primaryIndex = site.views.items.findIndex((item) => item.screenshot.src.includes("dashboard_testing_detail"));
const resolvedPrimaryIndex = primaryIndex === -1 ? site.views.items.length - 1 : primaryIndex;
const primaryView = site.views.items[resolvedPrimaryIndex];
const secondaryViews = site.views.items
  .map((item, index) => ({ item, index }))
  .filter(({ index }) => index !== resolvedPrimaryIndex);
const accentStyles = [
  {
    panel: "border-l-[3px] border-l-cyan-400/60",
    label: "text-cyan-300/80",
    chip: "border-cyan-400/20 bg-cyan-400/10 text-cyan-100",
  },
  {
    panel: "border-l-[3px] border-l-warning/50",
    label: "text-warning/80",
    chip: "border-warning/20 bg-warning/10 text-warning",
  },
  {
    panel: "border-l-[3px] border-l-emerald-400/50",
    label: "text-emerald-300/80",
    chip: "border-emerald-400/20 bg-emerald-400/10 text-emerald-100",
  },
];
const primaryAccent = accentStyles[resolvedPrimaryIndex] ?? accentStyles[0];
---

<section id="views" class="presentation-slide">
  <div class="container-shell">
    <SectionHeading eyebrow={site.views.eyebrow} title={site.views.title} intro={site.views.intro} />

    <div class="mt-14 grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
      <article class:list={[
        "surface-panel overflow-hidden border-t border-r border-b border-white/10 bg-white/[0.03]",
        primaryAccent.panel,
      ]}>
        <div class="border-b border-white/10 px-6 py-5 sm:px-8">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class:list={["text-sm uppercase tracking-[0.18em]", primaryAccent.label]}>{primaryView.label}</p>
              <h3 class="mt-2 text-2xl font-semibold text-foreground sm:text-[2rem]">{primaryView.name}</h3>
            </div>
            <span class:list={["inline-flex items-center rounded-full border px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.2em]", primaryAccent.chip]}>
              {primaryView.name}
            </span>
          </div>
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300">{primaryView.description}</p>
        </div>
        <div class="bg-slate-950/70 p-3 sm:p-4">
          <img
            src={withBase(primaryView.screenshot.src)}
            alt={primaryView.screenshot.alt}
            class="w-full rounded-[1.15rem] border border-white/10 object-contain object-top"
          />
        </div>
      </article>

      <div class="grid gap-6">
        {secondaryViews.map(({ item, index }) => (
          <article class:list={[
            "surface-panel overflow-hidden border-t border-r border-b border-white/10 bg-white/[0.02]",
            (accentStyles[index] ?? accentStyles[0]).panel,
          ]}>
            <div class="bg-slate-950/70 p-3">
              <img
                src={withBase(item.screenshot.src)}
                alt={item.screenshot.alt}
                class="w-full rounded-[1rem] border border-white/10 object-contain object-top"
              />
            </div>
            <div class="border-t border-white/10 px-5 py-5 sm:px-6">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class:list={["text-sm font-medium uppercase tracking-[0.18em]", (accentStyles[index] ?? accentStyles[0]).label]}>
                    {item.label}
                  </p>
                  <h3 class="mt-2 text-2xl font-semibold text-foreground">{item.name}</h3>
                </div>
                <span class:list={[
                  "inline-flex items-center rounded-full border px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.2em]",
                  (accentStyles[index] ?? accentStyles[0]).chip,
                ]}>
                  {item.name}
                </span>
              </div>
              <p class="mt-3 text-base leading-relaxed text-slate-300">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
