---
import SectionHeading from "../ui/SectionHeading.astro";
import { site } from "../../data/site.ts";
---

<section id="features" class="py-24 sm:py-36">
  <div class="container-shell">
    <SectionHeading eyebrow={site.features.eyebrow} title={site.features.title} />

    <div class="mt-14 grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="rounded-[2rem] bg-cyan-400 p-8 text-slate-950 shadow-glow sm:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-900/70">featured capability</p>
        <h3 class="mt-5 text-3xl font-bold tracking-tight sm:text-4xl">{site.features.featured.title}</h3>
        <p class="mt-5 text-base leading-relaxed text-slate-900/80 sm:text-lg">{site.features.featured.description}</p>
      </div>

      <div class="space-y-6">
        {site.features.items.map((item, index) => (
          <div class="surface-panel border-l-[3px] border-l-cyan-400/55 p-6 sm:p-7">
            <div class="text-xs font-mono uppercase tracking-[0.22em] text-cyan-300/75">
              feature {String(index + 1).padStart(2, "0")}
            </div>
            <h3 class="mt-2 text-xl font-semibold text-foreground">{item.title}</h3>
            <p class="mt-3 text-base leading-relaxed text-muted-foreground">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
