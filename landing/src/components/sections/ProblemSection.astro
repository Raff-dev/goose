---
import SectionHeading from "../ui/SectionHeading.astro";
import { site } from "../../data/site.ts";
---

<section id="problem" class="py-24 sm:py-32">
  <div class="container-shell">
    <SectionHeading eyebrow={site.problem.eyebrow} title={site.problem.title} intro={site.problem.intro} />

    <div class="mt-14 grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-12 md:gap-y-14">
      {site.problem.items.map((item, index) => (
        <div
          class:list={[
            "border-l-[3px] pl-5",
            index === 0
              ? "border-l-warning md:col-span-12 md:max-w-3xl"
              : index === 1
                ? "border-l-warning/70 md:col-span-7"
                : index === 2
                  ? "border-l-warning/50 md:col-span-5"
                  : "border-l-warning/30 md:col-span-7 md:col-start-4",
          ]}
        >
          <span class="text-sm font-mono text-muted-foreground/55">{String(index + 1).padStart(2, "0")}</span>
          <h3 class="mt-1 text-xl font-semibold leading-snug text-foreground sm:text-2xl">{item.title}</h3>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-300">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
