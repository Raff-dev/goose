---
import { site } from "../../data/site.ts";
import CodeBlock from "../ui/CodeBlock.astro";

const section = site.presentation.cli;
---

<section id="cli" class="presentation-slide">
  <div class="container-shell grid gap-10 lg:grid-cols-[0.34fr_0.66fr] lg:items-center">
    <div>
      <p class="presentation-kicker">{section.step} / {section.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        {section.title}
      </h2>
      <p class="section-copy mt-6 max-w-2xl">{section.body}</p>

      <div class="mt-8 flex flex-wrap gap-3">
        {section.anatomy.map((item) => (
          <span class="presentation-chip">{item}</span>
        ))}
      </div>
    </div>

    <div class="lg:justify-self-end lg:w-full">
      <CodeBlock label={section.codeLabel} code={section.code} lang="python" size="sm" />
    </div>
  </div>
</section>
