---
interface Point {
  label: string;
  title?: string;
  text: string;
}

interface SectionData {
  step: string;
  eyebrow: string;
  title: string;
  body: string;
  points: readonly Point[];
}

interface Props {
  id: string;
  section: SectionData;
}

const { id, section } = Astro.props;
const pointsGridClass = section.points.length === 2 ? "sm:grid-cols-2" : "sm:grid-cols-3";
---

<section id={id} class="presentation-slide">
  <div class="container-shell grid gap-10 lg:grid-cols-[0.42fr_0.58fr] lg:items-center">
    <div>
      <p class="presentation-kicker">{section.step} / {section.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        {section.title}
      </h2>
      <p class="section-copy mt-6 max-w-2xl">{section.body}</p>
    </div>

    <div class={`grid gap-4 ${pointsGridClass}`}>
      {section.points.map((point) => (
        <div class="presentation-note">
          <div class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300/80">{point.label}</div>
          {point.title && <h3 class="mt-3 text-xl font-semibold tracking-tight text-foreground">{point.title}</h3>}
          <p class="mt-3 text-sm leading-relaxed text-slate-200">{point.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
