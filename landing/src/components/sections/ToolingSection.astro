---
import CodeBlock from "../ui/CodeBlock.astro";
import { site } from "../../data/site.ts";

const section = site.presentation.tooling;
---

<section id="tooling" class="presentation-slide">
  <div class="container-shell grid gap-10 lg:grid-cols-[0.34fr_0.66fr] lg:items-center">
    <div>
      <p class="presentation-kicker">{section.step} / {section.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        {section.title}
      </h2>
      <p class="section-copy mt-6 max-w-2xl">{section.body}</p>

      <p class="presentation-quote mt-8 max-w-xl">{section.bridge}</p>
    </div>

    <div class="surface-panel p-6 sm:p-7">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-slate-400">Direct tool invoke</p>
          <h3 class="mt-2 text-2xl font-semibold text-foreground">{section.toolName}</h3>
        </div>
        <span class="presentation-chip">Tooling</span>
      </div>

      <div class="mt-6 space-y-4">
        <CodeBlock label={section.argsLabel} code={section.args} lang="json" size="sm" />
        <CodeBlock label={section.outputLabel} code={section.output} lang="json" size="sm" />
      </div>

      <p class="mt-6 text-sm leading-relaxed text-slate-200">{section.supportingLine}</p>
    </div>
  </div>
</section>
