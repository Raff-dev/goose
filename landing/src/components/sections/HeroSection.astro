---
import ButtonLink from "../ui/ButtonLink.astro";
import { site } from "../../data/site.ts";
import { withBase } from "../../lib/paths.ts";
---

<section class="relative overflow-hidden pt-32 pb-24 sm:pt-40 sm:pb-32">
  <div class="pointer-events-none absolute -right-24 top-12 hidden select-none lg:block xl:-right-10 xl:top-10" aria-hidden="true">
    <img
      src={withBase("/images/goos_transparent.png")}
      alt=""
      class="w-[24rem] max-w-none opacity-[0.07] saturate-[0.82] mix-blend-screen xl:w-[30rem]"
      loading="eager"
      decoding="async"
    />
  </div>

  <div class="relative z-10 container-shell">
    <div class="mx-auto max-w-4xl text-center">
      <p class="eyebrow">{site.hero.eyebrow}</p>
      <h1 class="mt-6 text-4xl font-bold leading-[1.05] tracking-tight text-foreground sm:text-5xl lg:text-6xl">
        {site.hero.title}
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
        {site.hero.subtitle}
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <ButtonLink href={site.hero.primaryCta.href} external>{site.hero.primaryCta.label}</ButtonLink>
        {site.hero.secondaryCtas.slice(0, 1).map((cta) => (
          <ButtonLink href={cta.href} variant="secondary" external>{cta.label}</ButtonLink>
        ))}
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        {site.hero.badgeItems.map((item) => (
          <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-slate-200">
            {item}
          </span>
        ))}
      </div>
    </div>

    <div class="mt-14 grid items-center gap-8 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="surface-panel overflow-hidden p-6 sm:p-8">
        <div class="mb-6 flex flex-wrap gap-3">
          {site.hero.stats.map((item) => (
            <div class="rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3">
              <div class="text-2xl font-bold text-cyan-300">{item.value}</div>
              <div class="mt-1 max-w-[12rem] text-sm text-muted-foreground">{item.label}</div>
            </div>
          ))}
        </div>

        <div class="space-y-5 text-left">
          {site.hero.supportingPoints.map((point, index) => (
            <div class="border-l-[3px] border-l-cyan-400/70 pl-4">
              <div class="text-sm font-mono uppercase tracking-[0.18em] text-cyan-300/70">
                {String(index + 1).padStart(2, "0")}
              </div>
              <p class="mt-1 text-base leading-relaxed text-slate-100">{point}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="terminal-panel p-6 sm:p-8">
        <div class="flex items-center justify-between border-b border-white/8 pb-4">
          <span class="text-sm font-medium uppercase tracking-[0.18em] text-slate-400">Why the tests hold up</span>
          <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs text-emerald-300">
            natural-language validation
          </span>
        </div>
        <div class="mt-6 space-y-4">
          <div class="rounded-2xl border border-white/8 bg-white/[0.03] p-4">
            <p class="text-sm text-slate-400">Expectation</p>
            <p class="mt-2 text-base text-slate-100">“Agent created a sale transaction and then checked remaining inventory.”</p>
          </div>
          <div class="rounded-2xl border border-cyan-400/20 bg-cyan-400/8 p-4">
            <p class="text-sm text-cyan-200">Required tools</p>
            <p class="mt-2 font-mono text-sm text-slate-100">[check_inventory, create_sale]</p>
          </div>
          <div class="rounded-2xl border border-amber-300/15 bg-amber-300/8 p-4">
            <p class="text-sm text-amber-200">Result</p>
            <p class="mt-2 text-sm leading-7 text-slate-100">
              Goose validates the behavior semantically, checks whether the right tools ran, and keeps the trace ready for the next rerun.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
