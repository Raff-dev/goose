---
import { site } from "../../data/site.ts";
import { withBase } from "../../lib/paths.ts";

const chrome = site.presentation.chrome;
---

<div class="pointer-events-none fixed inset-x-0 top-4 z-50">
  <div class="container-shell flex items-start justify-between gap-4">
    <a
      href={withBase("/")}
      class="pointer-events-auto inline-flex items-center gap-3 rounded-full border border-white/10 bg-slate-950/75 px-4 py-3 shadow-soft backdrop-blur-xl"
    >
      <img
        src={withBase("/images/goos_transparent.png")}
        alt="Goose"
        class="h-10 w-10 rounded-full border border-white/10 bg-white/5 object-contain p-1.5"
      />
      <div>
        <div class="text-sm font-semibold text-foreground">{chrome.brand}</div>
        <div class="text-[0.68rem] uppercase tracking-[0.22em] text-muted-foreground">{chrome.kicker}</div>
      </div>
    </a>

    <div class="pointer-events-auto hidden items-center gap-3 sm:flex">
      <span class="rounded-full border border-white/10 bg-slate-950/70 px-4 py-2 text-[0.68rem] uppercase tracking-[0.22em] text-muted-foreground">
        {chrome.kicker}
      </span>
      <a
        href={withBase(chrome.appendixHref)}
        class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-4 py-2.5 text-sm font-semibold text-foreground transition hover:border-cyan-300/40 hover:text-cyan-100"
      >
        {chrome.appendixLabel}
      </a>
      <a
        href={chrome.primaryCta.href}
        target="_blank"
        rel="noreferrer noopener"
        class="inline-flex items-center justify-center rounded-full bg-cyan-400 px-5 py-2.5 text-sm font-semibold text-slate-950 shadow-glow transition hover:bg-cyan-300"
      >
        {chrome.primaryCta.label}
      </a>
    </div>
  </div>
</div>
